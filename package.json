{
  "name": "openverify",
  "version": "1.0.0",
  "private": true,
  "description": "Open-source Discord verification and backup OAuth2 bot system",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "db:generate": "pnpm --filter @openverify/database db:generate",
    "db:push": "pnpm --filter @openverify/database db:push",
    "db:migrate": "pnpm --filter @openverify/database db:migrate",
    "db:seed": "pnpm --filter @openverify/database db:seed"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^1.13.3",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.0.6"
}
